{
    // Change this to match your project
    "include": ["lib/**/*.js"],
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2023",
        "checkJs": true,
        "skipLibCheck": true,
        // Tells TypeScript to read JS files, as
        // normally they are ignored as source files
        "allowJs": true,
        // This compiler run should
        // only output d.ts files
        "noEmit": true
    }
}
